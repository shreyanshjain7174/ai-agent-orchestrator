# Azure AI Configuration
# For production: Use Microsoft Foundry models (recommended)
# AZURE_AI_PROJECT_ENDPOINT=https://your-project.api.azureml.ms
# AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.1

# For development: Use GitHub Models (free tier)
# Get your GitHub token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here
AZURE_AI_PROJECT_ENDPOINT=https://models.github.ai/inference/

# Model Configuration
# Architect: Reasoning and design (gpt-5.1, o3, claude-opus-4-5)
AZURE_AI_MODEL_DEPLOYMENT_NAME=openai/gpt-5.1

# Specialized model routing for Copilot MCP tools.
# Architect and Developer are pinned to Claude Opus by default.
ARCHITECT_MODEL=anthropic/claude-opus-4.6
DEVELOPER_MODEL=anthropic/claude-opus-4.6

# Keep QA and other roles on auto to use AZURE_AI_MODEL_DEPLOYMENT_NAME fallback.
QA_MODEL=auto
MANAGER_MODEL=auto

# Autonomous Orchestrator Model Routing
# For Plan-Eval-Gather-Execute-Verify loop agents
PLANNER_MODEL=auto
EVALUATOR_MODEL=auto
RESEARCHER_MODEL=auto
VERIFIER_MODEL=auto

# Optional: Use different models for different agents
# ARCHITECT_MODEL=openai/gpt-5.1
# DEVELOPER_MODEL=openai/gpt-5.1-codex
# QA_MODEL=openai/o3
# PLANNER_MODEL=openai/gpt-5.1
# EVALUATOR_MODEL=openai/o3-mini
# RESEARCHER_MODEL=anthropic/claude-opus-4.6

# Orchestrator Configuration
MAX_ITERATIONS=5
MAX_AUTONOMOUS_ITERATIONS=10
ENABLE_PARALLEL_TASKS=true
ENABLE_SKILL_DISCOVERY=true

# Logging
LOG_LEVEL=INFO
